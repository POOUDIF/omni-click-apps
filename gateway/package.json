    "sanitize-html": "^2.13.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0"
