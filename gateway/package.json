{
  "name": "omniclick-webhook-gateway",
  "version": "1.0.0",
  "description": "High-throughput webhook receiver for OmniClick omnichannel platform",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env LOG_LEVEL=debug NODE_ENV=development node --watch server.js",
