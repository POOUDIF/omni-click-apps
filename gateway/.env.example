# Gateway Port
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
# Atau gunakan URL lengkap: RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# SQL Server (untuk channel lookup & credential resolve)
DB_HOST=localhost
DB_PORT=1433
DB_DATABASE=omnichannel
DB_USERNAME=sa
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Laravel APP_KEY (digunakan untuk decrypt channel credentials dari SQL)
# Salin dari backend/.env
APP_KEY=base64:...

# WhatsApp verification token (untuk challenge verification saat setup channel)
WA_VERIFY_TOKEN=your-verify-token-here
