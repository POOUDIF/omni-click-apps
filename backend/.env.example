APP_NAME="OmniClick"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# SQL Server — Primary Database
DB_CONNECTION=sqlsrv
DB_HOST=localhost
DB_PORT=1433
DB_DATABASE=omnichannel
DB_USERNAME=sa
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# MongoDB — Message Storage
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=omnichannel_messages

# Session, Cache, Queue
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=rabbitmq
CACHE_STORE=redis

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Internal API Security
INTERNAL_API_KEY=generate-random-256-bit-hex

# Channel Credential Encryption (must be exactly 32 chars)
CREDENTIAL_ENCRYPTION_KEY=generate-32-char-key-here-xxxxxxx

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@omniclick.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
