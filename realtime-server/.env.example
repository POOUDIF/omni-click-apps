PORT=3002
NODE_ENV=development

# Redis — HARUS dua connection: satu untuk subscriber, satu untuk publisher/general
REDIS_URL=redis://127.0.0.1:6379

# JWT secret HARUS sama persis dengan APP_JWT_SECRET di Laravel .env
APP_JWT_SECRET=your-jwt-secret-here

# Laravel Internal API
LARAVEL_INTERNAL_URL=http://localhost:8000
INTERNAL_API_KEY=your-internal-api-key-here

# Socket.io CORS — pisahkan dengan koma jika lebih dari satu origin
ALLOWED_ORIGINS=http://localhost:5173

LOG_LEVEL=debug
